# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.eggs/
dist/
build/
.env
.venv
env/

# ── Jupyter ───────────────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Benchmark data (too large for git) ───────────────────────────────────────
# Keep data/splits/ (small CSVs) and directory skeletons (.gitkeep files).
data/raw/uni/*
data/raw/multi/*
data/scores/uni/*
data/scores/multi/*
data/metrics/uni/*
data/metrics/multi/*
data/runtime/uni/*
data/runtime/multi/*
!**/.gitkeep

# ── Test / cache ──────────────────────────────────────────────────────────────
.pytest_cache/

# ── OS / IDE ──────────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
